{
  "name": "kle-serial-alt",
  "version": "0.1.0",
  "description": "Alternative KLE (Keyboard Layout Editor) raw data parser with rx/ry rotation cluster fixes. Drop-in replacement for @ijprest/kle-serial.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "kle",
    "keyboard-layout-editor",
    "keyboard",
    "layout",
    "mechanical-keyboard",
    "qmk",
    "parser",
    "deserialize"
  ],
  "author": "digitarhythm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digitarhythm/kle-serial-alt.git"
  },
  "bugs": {
    "url": "https://github.com/digitarhythm/kle-serial-alt/issues"
  },
  "homepage": "https://github.com/digitarhythm/kle-serial-alt#readme",
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
